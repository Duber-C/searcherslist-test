aws_region              = "us-east-1"
project_name            = "searchers-backend"
environment             = "prod"
repository_full_name    = "org-or-user/searchers-backend"
repository_branch       = "main"
codestar_connection_arn = "arn:aws:codestar-connections:us-east-1:123456789012:connection/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

db_name     = "searchers"
db_username = "postgres"
db_password = "replace-me"

allowed_ssh_cidrs = ["203.0.113.10/32"]

django_env = {
  SECRET_KEY           = "replace-me"
  ALLOWED_HOSTS        = "api.example.com,localhost,127.0.0.1"
  CORS_ALLOWED_ORIGINS = "https://www.example.com"
  CSRF_TRUSTED_ORIGINS = "https://www.example.com,https://api.example.com"
  OPENAI_API_KEY       = "replace-me"
  CHAT_GPT_SECRET_KEY  = "replace-me"
}

