# Copy this file to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars — it contains secrets.

aws_region   = "us-east-1"
project_name = "searcherlist"
environment  = "prod"

# --- EC2 ---
ec2_instance_type = "t3.small"
ec2_key_pair_name = "your-key-pair-name"
# ec2_ami_id default is Amazon Linux 2023 us-east-1 — override if needed

# --- RDS ---
db_name     = "searcherlist"
db_username = "postgres"
db_password = "CHANGE_ME_strong_password"

# --- Django ---
django_secret_key    = "CHANGE_ME_django_secret_key"
django_allowed_hosts = "api.searcherlist.com"
cors_allowed_origins = "https://www.searcherlist.com"
openai_api_key       = ""

# --- S3 ---
media_bucket_name  = "searcherlist-media-prod"
static_bucket_name = "searcherlist-static-prod"

# --- GitHub ---
github_owner       = "your-github-username-or-org"
github_repo        = "searchers-backend"
github_branch      = "main"
github_oauth_token = "ghp_CHANGE_ME"
