#!/bin/bash
set -euxo pipefail

dnf update -y
dnf install -y docker git curl

mkdir -p /usr/local/lib/docker/cli-plugins
curl -SL "https://github.com/docker/compose/releases/latest/download/docker-compose-linux-x86_64" \
  -o /usr/local/lib/docker/cli-plugins/docker-compose
chmod +x /usr/local/lib/docker/cli-plugins/docker-compose

# Fail the bootstrap immediately if the instance is missing deploy prerequisites.
command -v git >/dev/null 2>&1
command -v docker >/dev/null 2>&1
docker compose version >/dev/null 2>&1

systemctl enable --now docker
usermod -aG docker ec2-user

mkdir -p ${app_dir}
chown ec2-user:ec2-user ${app_dir}

if [ ! -d "${app_dir}/.git" ]; then
  sudo -u ec2-user git clone --branch ${repo_branch} ${repo_url} ${app_dir}
else
  cd ${app_dir}
  sudo -u ec2-user git fetch --all
  sudo -u ec2-user git checkout ${repo_branch}
  sudo -u ec2-user git pull --ff-only origin ${repo_branch}
fi

cat > ${app_dir}/.env.production <<'ENVEOF'
SECRET_KEY=${django_secret_key}
DEBUG=${debug}
DJANGO_SETTINGS_MODULE=${django_settings_module}
ALLOWED_HOSTS=${allowed_hosts}
CORS_ALLOWED_ORIGINS=${cors_allowed_origins}
CSRF_TRUSTED_ORIGINS=${csrf_trusted_origins}
CHAT_GPT_SECRET_KEY=${chat_gpt_secret_key}
OPENAI_API_KEY=${openai_api_key}
EMAIL_BACKEND=${email_backend}
DEFAULT_FROM_EMAIL=${default_from_email}
AWS_ACCESS_KEY_ID=${aws_access_key_id}
AWS_SECRET_ACCESS_KEY=${aws_secret_access_key}
AWS_SES_REGION_NAME=${aws_ses_region_name}
AWS_SES_REGION_ENDPOINT=${aws_ses_region_endpoint}
ENVEOF

cat > ${app_dir}/.env.db <<'ENVEOF'
POSTGRES_DB=${db_name}
POSTGRES_USER=${db_username}
POSTGRES_PASSWORD=${db_password}
POSTGRES_HOST=${db_host}
POSTGRES_PORT=${db_port}
ENVEOF

cat > ${app_dir}/.env.compose <<'ENVEOF'
APP_PORT=${app_port}
ENVEOF

chown ec2-user:ec2-user ${app_dir}/.env.production ${app_dir}/.env.db ${app_dir}/.env.compose

cat > /etc/systemd/system/searchers-backend.service <<EOF
[Unit]
Description=Searchers backend Docker Compose service
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
WorkingDirectory=${app_dir}
RemainAfterExit=yes
ExecStart=/usr/bin/docker compose --env-file .env.compose -f prod.yml up -d --build --no-deps django
ExecStop=/usr/bin/docker compose --env-file .env.compose -f prod.yml stop django
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
EOF

cd ${app_dir}
docker compose --env-file .env.compose -f prod.yml up -d --build --no-deps django
systemctl daemon-reload
systemctl enable searchers-backend.service
